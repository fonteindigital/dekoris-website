        <div class="value-title">Quality Products</div>
        <div class="value-desc">Premium materials from trusted brands.</div>
      </div>
      <div class="value-item fade-up" style="transition-delay: 0.1s">
        <div class="value-icon">
          <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <div class="value-title">Exceptional Service</div>
        <div class="value-desc">From consultation to aftercare.</div>
      </div>
      <div class="value-item fade-up" style="transition-delay: 0.2s">
        <div class="value-icon">
          <svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
        </div>
        <div class="value-title">Competitive Pricing</div>
        <div class="value-desc">Value without compromise.</div>
      </div>
      <div class="value-item fade-up" style="transition-delay: 0.3s">
        <div class="value-icon">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/></svg>
        </div>
        <div class="value-title">Local Knowledge</div>
        <div class="value-desc">Deep understanding of the Namibian market.</div>
      </div>
    </div>
  </section>

  <!-- ═══════════ PRODUCTS (CMS-driven) ═══════════ -->
  <section class="section products">
    <div class="section-inner">
      <div class="products-header">
        <div>
          <div class="section-label fade-up">Our Products</div>
          <h2 class="section-title fade-up" style="transition-delay: 0.1s">Explore Our Range</h2>
        </div>
        <a href="/gallery/" class="btn btn-gold fade-up" style="transition-delay: 0.2s; flex-shrink: 0;">View All Products</a>
      </div>
      <div class="products-grid">
        {% for product in collections.products %}
        <div class="product-card fade-up" style="transition-delay: {{ loop.index0 * 0.05 }}s">
          <div class="product-image">
            <img src="{{ product.data.image }}" alt="{{ product.data.title }}">
          </div>
          <div class="product-info">
            <div class="product-name">{{ product.data.title }}</div>
            <div class="product-price"><span class="product-from">from</span>N${{ product.data.price | commaNumber }}</div>
            <button class="snipcart-add-item product-buy"
              data-item-id="{{ product.data.title | slug }}"
              data-item-name="{{ product.data.title }}"
              data-item-price="{{ product.data.price }}"
              data-item-url="https://dekoris.com.na/"
              data-item-image="{{ product.data.image }}"
              data-item-description="{{ product.data.description }}">Add to Cart</button>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- ═══════════ SERVICES ═══════════ -->
  <section class="section services">
    <div class="section-inner">
      <div class="section-label fade-up">Our Services</div>
      <h2 class="section-title fade-up" style="transition-delay: 0.1s">Explore Our Offerings</h2>
      <p class="section-subtitle fade-up" style="transition-delay: 0.15s">From concept to completion, we deliver tailored solutions for every space.</p>
      <div class="services-grid">
        <div class="service-card fade-up">
          <img src="https://static.wixstatic.com/media/06bb1b_7e48319a0d7b4169aa01f0916998faa4~mv2.jpg/v1/fill/w_800,h_900,al_c,q_80,enc_avif,quality_auto/IMG_6352.jpg" alt="Residential Installations">
          <div class="service-overlay">
            <div class="service-card-title">Residential Installations</div>
            <div class="service-card-desc">Custom blinds and curtains for living rooms, bedrooms, and kitchens, with both manual and motorised options.</div>
          </div>
        </div>
        <div class="service-card fade-up" style="transition-delay: 0.1s">
          <img src="https://static.wixstatic.com/media/11062b_b2a88fae29a24406aee5e162858814af~mv2.jpg/v1/fill/w_800,h_900,al_c,q_80,enc_avif,quality_auto/Business%20Meeting.jpg" alt="Commercial Installations">
          <div class="service-overlay">
            <div class="service-card-title">Commercial Installations</div>
            <div class="service-card-desc">Window treatment solutions for offices, conference rooms, and common areas, focused on light control, privacy, and energy efficiency.</div>
          </div>
        </div>
        <div class="service-card fade-up" style="transition-delay: 0.2s">
          <img src="https://static.wixstatic.com/media/06bb1b_4868bf03372a428da74ad1f99b87c497~mv2.jpg/v1/fill/w_800,h_900,al_c,q_80,enc_avif,quality_auto/06bb1b_4868bf03372a428da74ad1f99b87c497~mv2.jpg" alt="Healthcare Facilities">
          <div class="service-overlay">
            <div class="service-card-title">Healthcare Facilities</div>
            <div class="service-card-desc">Specialised blinds and curtains using anti-microbial, easy-to-clean materials that comply with healthcare standards.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ GALLERY STRIP ═══════════ -->
