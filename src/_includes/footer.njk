<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div class="nav-logo">
        {% if settings.logoDark %}
          <img src="{{ settings.logoDark }}" alt="{{ settings.siteName or 'Dekoris' }}" style="height: 50px; width: auto;">
        {% elif settings.logo %}
          <img src="{{ settings.logo }}" alt="{{ settings.siteName or 'Dekoris' }}" style="height: 50px; width: auto;">
        {% else %}
          <span class="nav-logo-text">{{ settings.siteName or "DEKORIS" }}</span>
          <span class="nav-logo-tagline">{{ settings.tagline or "Crafting Beautiful Spaces" }}</span>
        {% endif %}
      </div>
      <p>Proudly Namibian, 100% female-owned interiors company delivering premium blinds, curtains, and décor solutions.</p>
    </div>

    <div>
      <div class="footer-heading">Navigation</div>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about/">About Us</a></li>
        <li><a href="/gallery/">Gallery</a></li>
        <li><a href="/inspiration/">Inspiration</a></li>
        <li><a href="/faqs/">FAQs</a></li>
        <li><a href="/contact/">Contact Us</a></li>
      </ul>
    </div>

    <div>
      <div class="footer-heading">Contact</div>
      <ul class="footer-links">
        {% if settings.phone %}
          <li><a href="tel:{{ settings.phone | replace(' ', '') }}">{{ settings.phone }}</a></li>
        {% endif %}
        {% if settings.email %}
          <li><a href="mailto:{{ settings.email }}">{{ settings.email }}</a></li>
        {% endif %}
        <li><a href="https://www.dekoris.com.na" target="_blank" rel="noopener noreferrer">www.dekoris.com.na</a></li>
        {% if settings.whatsapp %}
          <li><a href="https://wa.me/{{ settings.whatsapp }}" target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
        {% endif %}
        {% if settings.address %}
          <li>{{ settings.address }}</li>
        {% endif %}
      </ul>
    </div>

    <div class="footer-newsletter">
      <div class="footer-heading">Subscribe for Updates</div>
      <p>Get the latest on new products, trends, and exclusive offers delivered to your inbox.</p>
      <div class="footer-newsletter-form">
        <input type="email" placeholder="Your email">
        <button type="button">Subscribe</button>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; 2026 {{ settings.siteName or "Dekoris" }}. All rights reserved.</p>
    <p>Website by <a href="http://www.fontein.digital" target="_blank" rel="noopener noreferrer">Fontein.Digital</a></p>
  </div>
</footer>
