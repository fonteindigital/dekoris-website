<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle | default("Dekoris — Crafting Beautiful Spaces") }}</title>
  <meta name="description" content="{{ pageDescription | default('Dekoris is a proudly Namibian, 100% female-owned interiors company specialising in blinds, curtains, wall panelling, décor, and soft finishes.') }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  {% if includeSnipcart %}
  <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.4.1/default/snipcart.css" />
  {% endif %}
  <script async src="https://cdn.jsdelivr.net/npm/netlify-identity-widget@1.9.1/build/netlify-identity-widget.min.js"></script>
</head>
<body>
  {% include "nav.njk" %}

  {{ content | safe }}

  {% include "footer.njk" %}

  <!-- Common scripts -->
  <script>
    // Nav scroll effect
    window.addEventListener('scroll', () => {
      document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 20);
    });

    // Mobile menu toggle
    const toggle = document.querySelector('.nav-mobile-toggle');
    const navLinks = document.querySelector('.nav-links');
    if (toggle) {
      toggle.addEventListener('click', () => {
        toggle.classList.toggle('active');
        navLinks.classList.toggle('open');
      });
    }

    // Fade-up animations on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
  </script>

  {% if includeSnipcart %}
  <!-- Snipcart -->
  <div hidden id="snipcart" data-api-key="YzgxZDlmNDUtM2YzYi00YjQ5LWI0Y2QtYTBiOGVlY2Q5NTQ1NjM5MTE3NTczNDY1ODA5MjM2" data-currency="ZAR" data-config-modal-style="side"></div>
  <script async src="https://cdn.snipcart.com/themes/v3.4.1/default/snipcart.js"></script>
  {% endif %}

  <!-- Netlify Identity redirect for CMS -->
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; });
      });
    }
  </script>
</body>
</html>
